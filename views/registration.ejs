<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Institut Mittag-Leffler</title>
  <link rel="icon" type="image/png" href="/images/mittag-leffler-logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="header-content">
      <img src="/images/IML_bla.png" alt="Institut Mittag-Leffler - The Royal Swedish Academy of Sciences" style="height: 80px; width: auto;">
    </div>
  </header>

  <!-- Main Content -->
  <main class="container">
    <% if (program) { %>
      <h2 class="program-name" style="color: #003E7E; margin-bottom: 0.25rem;"><%= program.name %></h2>
      <% if (typeof workshop !== 'undefined' && workshop) { %>
        <h3 style="color: #666; margin: 0 0 0.5rem 0; font-size: 1rem;"><%= workshop.name %></h3>
      <% } %>
      <% if (program.start_date) { %>
        <p style="color: #666; margin-bottom: 1rem;">
          <%= new Date(program.start_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
          &ndash;
          <%= new Date(program.end_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
        </p>
      <% } %>
      <% if (program.description) { %>
        <div class="info-box" style="margin-bottom: 1.5rem;">
          <p><%= program.description %></p>
        </div>
      <% } %>
    <% } %>
    <h2 class="page-title">Submit Your Research Talk</h2>
    <p class="page-subtitle">Please fill out the form below to submit your research talk proposal</p>

    <% if (errors && errors.length > 0) { %>
      <div class="error-list">
        <ul>
          <% errors.forEach(error => { %>
            <li><%= error.msg %></li>
          <% }); %>
        </ul>
      </div>
    <% } %>

    <div class="form-card">
      <form action="<%= (typeof workshopId !== 'undefined' && workshopId) ? '/p/' + programId + '/ws/' + workshopId + '/register' : (programId ? '/p/' + programId + '/register' : '/api/submit') %>" method="POST" id="talkForm">
        <input type="hidden" name="programId" value="<%= programId || '' %>">
        <input type="hidden" name="workshopId" value="<%= typeof workshopId !== 'undefined' ? workshopId : '' %>">
        <!-- Personal Information -->
        <div class="form-row">
          <div class="form-group">
            <label for="firstName" class="form-label">
              First Name <span class="required">*</span>
            </label>
            <input
              type="text"
              id="firstName"
              name="firstName"
              class="form-input"
              value="<%= formData.firstName || '' %>"
              required
            >
          </div>

          <div class="form-group">
            <label for="lastName" class="form-label">
              Last Name <span class="required">*</span>
            </label>
            <input
              type="text"
              id="lastName"
              name="lastName"
              class="form-input"
              value="<%= formData.lastName || '' %>"
              required
            >
          </div>
        </div>

        <!-- Affiliation -->
        <div class="form-group">
          <label for="affiliation" class="form-label">
            Affiliation <span class="required">*</span>
          </label>
          <input
            type="text"
            id="affiliation"
            name="affiliation"
            class="form-input"
            placeholder="University or Institution"
            value="<%= formData.affiliation || '' %>"
            required
          >
        </div>

        <!-- Talk Title -->
        <div class="form-group">
          <label for="talkTitle" class="form-label">
            Title of Your Talk <span class="required">*</span>
          </label>
          <input
            type="text"
            id="talkTitle"
            name="talkTitle"
            class="form-input"
            value="<%= formData.talkTitle || '' %>"
            required
          >
        </div>

        <!-- Talk Abstract -->
        <div class="form-group">
          <label for="talkAbstract" class="form-label">
            Abstract of Your Talk <span class="required">*</span>
          </label>
          <textarea
            id="talkAbstract"
            name="talkAbstract"
            class="form-textarea"
            required
            minlength="50"
          ><%= formData.talkAbstract || '' %></textarea>
          <small class="form-helper">
            Please provide a detailed abstract of at least 50 characters.
          </small>
        </div>

        <!-- Questions -->
        <div class="form-group">
          <label for="questions" class="form-label">
            Any Questions?
          </label>
          <textarea
            id="questions"
            name="questions"
            class="form-textarea"
            placeholder="Please enter any questions or additional comments here..."
          ><%= formData.questions || '' %></textarea>
        </div>

        <!-- Submit Button -->
        <div class="btn-group">
          <button type="submit" class="btn btn-primary">Submit</button>
        </div>
      </form>
    </div>

    <!-- Contact Information -->
    <div class="info-box">
      <h3>Contact</h3>
      <p>For questions, please contact the program organizers.</p>
    </div>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <p>&copy; <%= new Date().getFullYear() %> Institut Mittag-Leffler</p>
    <p>The Royal Swedish Academy of Sciences</p>
  </footer>

  <script src="/js/form.js"></script>
</body>
</html>
