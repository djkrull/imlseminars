<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Institut Mittag-Leffler</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .back-link {
      display: inline-block;
      color: #003E7E;
      text-decoration: none;
      font-size: 0.9rem;
      margin-bottom: 1rem;
      transition: opacity 0.2s;
    }
    .back-link:hover {
      opacity: 0.7;
    }
    .program-subtitle {
      color: #666;
      font-size: 0.95rem;
      margin: 0.25rem 0 1rem 0;
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="header">
    <div class="header-content">
      <img src="/images/IML_bla.png" alt="Institut Mittag-Leffler - The Royal Swedish Academy of Sciences" style="height: 80px; width: auto;">
    </div>
  </header>

  <!-- Main Content -->
  <main class="container" style="max-width: 1400px;">
    <% if (typeof role !== 'undefined' && role === 'admin') { %>
      <a href="/admin/programs" class="back-link">&larr; Back to Programs</a>
    <% } else { %>
      <a href="/admin/p/<%= programId %>/scheduling" class="back-link">&larr; Back to Schedule</a>
    <% } %>
    <h1><%= program ? program.name : 'Admin Dashboard' %></h1>
    <% if (program && program.start_date) { %>
      <p class="program-subtitle">
        <%= new Date(program.start_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
        &ndash;
        <%= new Date(program.end_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
      </p>
    <% } %>
    <div class="admin-header">
      <h2 class="page-title" style="margin: 0;">Talk Submissions</h2>
      <div class="admin-actions">
        <a href="/admin/p/<%= programId %>/scheduling" class="btn btn-secondary">
          Schedule Talks
        </a>
        <% if (typeof role !== 'undefined' && role === 'admin') { %>
          <a href="/klein-converter" class="btn btn-secondary">
            Klein Converter
          </a>
          <a href="/admin/p/<%= programId %>/export" class="btn btn-secondary">
            Export to Excel
          </a>
        <% } %>
        <a href="/admin/logout" class="btn btn-primary">
          Logout
        </a>
      </div>
    </div>

    <!-- Statistics -->
    <div class="stats-row">
      <div class="stat-card">
        <h3>Total Submissions</h3>
        <p><%= totalSubmissions %></p>
      </div>
      <div class="stat-card">
        <h3>Status</h3>
        <p>Active</p>
      </div>
    </div>

    <!-- Submissions Table -->
    <div class="table-container">
      <% if (talks && talks.length > 0) { %>
        <table class="table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Email</th>
              <th>Affiliation</th>
              <th>Talk Title</th>
              <th>Submitted</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% talks.forEach(talk => { %>
              <tr>
                <td>#<%= talk.id %></td>
                <td><%= talk.getFullName() %></td>
                <td><%= talk.email %></td>
                <td><%= talk.affiliation %></td>
                <td title="<%= talk.talkTitle %>"><%= talk.talkTitle %></td>
                <td>
                  <%= new Date(talk.submittedAt).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric'
                  }) %>
                </td>
                <td>
                  <div class="table-actions">
                    <a href="/admin/p/<%= programId %>/view/<%= talk.id %>" class="btn btn-primary btn-sm">
                      View
                    </a>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon">📭</div>
          <h3>No submissions yet</h3>
          <p>Talk submissions will appear here once researchers start submitting.</p>
        </div>
      <% } %>
    </div>

    <% if (typeof workshops !== 'undefined' && workshops && workshops.length > 0) { %>
      <div class="section-header" style="margin-top: 2rem;">
        <h3 style="color: #003E7E;">Workshops</h3>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem;">
        <% workshops.forEach(ws => { %>
          <div style="background: white; border-left: 4px solid <%= ws.color || '#969696' %>; border-radius: 6px; padding: 1rem 1.25rem; box-shadow: 0 1px 4px rgba(0,0,0,0.1); min-width: 200px;">
            <strong style="color: #003E7E;"><%= ws.name %></strong>
            <div style="font-size: 0.85rem; color: #666; margin: 0.25rem 0;">
              <%= new Date(ws.start_date).toLocaleDateString('en-GB', {day:'numeric',month:'short'}) %> – <%= new Date(ws.end_date).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'}) %>
            </div>
            <a href="/admin/p/<%= programId %>/ws/<%= ws.workshop_id %>/scheduling" class="btn btn-secondary" style="font-size: 0.8rem; padding: 0.25rem 0.6rem; margin-top: 0.5rem;">Schedule</a>
          </div>
        <% }); %>
      </div>
    <% } %>

    <% if (typeof role !== 'undefined' && role === 'admin') { %>
    <!-- Magic Links Management -->
    <div style="margin-top: 3rem;">
      <div class="admin-header">
        <h2 class="page-title" style="margin: 0;">External Scheduling Links</h2>
        <button class="btn btn-primary" onclick="showCreateLinkModal()">Create New Link</button>
      </div>
      <p style="color: #666; margin-bottom: 1rem;">
        Share these links with external users to give them access to the scheduling page. They can create and edit events but cannot publish, lock, or export.
      </p>
      <div class="table-container">
        <table class="table" id="magic-links-table">
          <thead>
            <tr>
              <th>Label</th>
              <th>Link</th>
              <th>Status</th>
              <th>Created</th>
              <th>Expires</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="magic-links-body">
            <tr><td colspan="6" style="text-align: center; color: #666;">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Create Link Modal -->
    <div id="link-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
      <div style="background: white; border-radius: 8px; padding: 2rem; max-width: 500px; width: 90%;">
        <h3 style="margin-top: 0; color: #003E7E;">Create Scheduling Link</h3>
        <form id="create-link-form">
          <div style="margin-bottom: 1rem;">
            <label style="display: block; margin-bottom: 0.5rem; font-weight: bold; color: #003E7E;">Label (optional)</label>
            <input type="text" id="link-label" placeholder="e.g., Spring 2026 Program Committee" style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
          </div>
          <div style="margin-bottom: 1rem;">
            <label style="display: block; margin-bottom: 0.5rem; font-weight: bold; color: #003E7E;">Expires (optional)</label>
            <input type="datetime-local" id="link-expires" style="width: 100%; padding: 0.5rem; border: 1px solid #ddd; border-radius: 4px;">
          </div>
          <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
            <button type="submit" class="btn btn-primary">Create Link</button>
            <button type="button" class="btn btn-secondary" onclick="closeLinkModal()">Cancel</button>
          </div>
        </form>
      </div>
    </div>
    <% } %>

    <div class="btn-group" style="margin-top: 2rem;">
      <a href="/" class="btn btn-primary">View Registration Form</a>
    </div>
  </main>

  <% if (typeof role !== 'undefined' && role === 'admin') { %>
  <script>
    // Magic Links Management
    async function loadMagicLinks() {
      try {
        const response = await fetch('/admin/magic-links?program_id=<%= programId %>', { credentials: 'same-origin' });
        const links = await response.json();
        const tbody = document.getElementById('magic-links-body');

        if (links.length === 0) {
          tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; color: #666;">No links created yet</td></tr>';
          return;
        }

        tbody.innerHTML = links.map(link => {
          const url = `${window.location.origin}/schedule/${link.token}`;
          const isActive = link.is_active && (!link.expires_at || new Date(link.expires_at) > new Date());
          const statusText = !link.is_active ? 'Deactivated' : (link.expires_at && new Date(link.expires_at) <= new Date() ? 'Expired' : 'Active');
          const statusColor = statusText === 'Active' ? '#228B22' : '#DC143C';

          return `<tr>
            <td>${link.label || '<em>No label</em>'}</td>
            <td>
              <button onclick="copyLink(this, '${url}')" style="padding: 0.3rem 0.75rem; border: 1px solid #003E7E; border-radius: 4px; cursor: pointer; background: #003E7E; color: white; font-size: 0.85rem;">Copy Link</button>
            </td>
            <td><span style="color: ${statusColor}; font-weight: bold;">${statusText}</span></td>
            <td>${new Date(link.created_at).toLocaleDateString()}</td>
            <td>${link.expires_at ? new Date(link.expires_at).toLocaleDateString() : 'Never'}</td>
            <td>
              ${link.is_active
                ? `<button onclick="deactivateLink(${link.id})" class="btn btn-sm" style="background: #DC143C; color: white; border: none; padding: 0.25rem 0.75rem; border-radius: 4px; cursor: pointer;">Deactivate</button>`
                : ''}
              <button onclick="deleteLink(${link.id})" class="btn btn-sm" style="background: #666; color: white; border: none; padding: 0.25rem 0.75rem; border-radius: 4px; cursor: pointer; margin-left: 0.25rem;">Delete</button>
            </td>
          </tr>`;
        }).join('');
      } catch (error) {
        console.error('Error loading magic links:', error);
      }
    }

    function showCreateLinkModal() {
      const modal = document.getElementById('link-modal');
      modal.style.display = 'flex';
      document.getElementById('create-link-form').reset();
    }

    function closeLinkModal() {
      document.getElementById('link-modal').style.display = 'none';
    }

    function copyLink(btn, url) {
      navigator.clipboard.writeText(url).then(() => {
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        btn.style.background = '#228B22';
        btn.style.borderColor = '#228B22';
        setTimeout(() => {
          btn.textContent = original;
          btn.style.background = '#003E7E';
          btn.style.borderColor = '#003E7E';
        }, 2000);
      });
    }

    async function deactivateLink(id) {
      if (!confirm('Deactivate this link? Users with this link will no longer be able to access the scheduling page.')) return;
      try {
        const response = await fetch(`/admin/magic-links/${id}/deactivate`, {
          method: 'POST',
          credentials: 'same-origin'
        });
        if (response.ok) {
          loadMagicLinks();
        } else {
          alert('Failed to deactivate link');
        }
      } catch (error) {
        console.error('Error deactivating link:', error);
      }
    }

    async function deleteLink(id) {
      if (!confirm('Delete this link permanently? This cannot be undone.')) return;
      try {
        const response = await fetch(`/admin/magic-links/${id}`, {
          method: 'DELETE',
          credentials: 'same-origin'
        });
        if (response.ok) {
          loadMagicLinks();
        } else {
          alert('Failed to delete link');
        }
      } catch (error) {
        console.error('Error deleting link:', error);
      }
    }

    document.getElementById('create-link-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const label = document.getElementById('link-label').value;
      const expiresAt = document.getElementById('link-expires').value;

      try {
        const response = await fetch('/admin/magic-links', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ label, expires_at: expiresAt || null, program_id: '<%= programId %>' }),
          credentials: 'same-origin'
        });

        if (response.ok) {
          closeLinkModal();
          loadMagicLinks();
        } else {
          alert('Failed to create link');
        }
      } catch (error) {
        console.error('Error creating link:', error);
      }
    });

    document.getElementById('link-modal').addEventListener('click', (e) => {
      if (e.target.id === 'link-modal') closeLinkModal();
    });

    // Load links on page load
    loadMagicLinks();
  </script>
  <% } %>

  <!-- Footer -->
  <footer class="footer">
    <p>&copy; <%= new Date().getFullYear() %> Institut Mittag-Leffler</p>
    <p>The Royal Swedish Academy of Sciences</p>
  </footer>
</body>
</html>
